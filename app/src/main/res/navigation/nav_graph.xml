<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_kick">

    <fragment
        android:id="@+id/navigation_kick"
        android:name="com.matrusneh.app.ui.kick.KickCounterFragment"
        android:label="Kick Counter"
        tools:layout="@layout/fragment_kick_counter" />

    <fragment
        android:id="@+id/navigation_checkup"
        android:name="com.matrusneh.app.ui.checkup.CheckupCountdownFragment"
        android:label="Checkups"
        tools:layout="@layout/fragment_checkup_countdown" />

    <fragment
        android:id="@+id/navigation_nutrition"
        android:name="com.matrusneh.app.ui.nutrition.NutritionPlateFragment"
        android:label="Nutrition"
        tools:layout="@layout/fragment_nutrition_plate" />

    <fragment
        android:id="@+id/navigation_alert"
        android:name="com.matrusneh.app.ui.alert.HealthAlertFragment"
        android:label="Health Alerts"
        tools:layout="@layout/fragment_health_alert" />

    <fragment
        android:id="@+id/navigation_vitals"
        android:name="com.matrusneh.app.ui.vitals.VitalsFragment"
        android:label="Vitals Tracker"
        tools:layout="@layout/fragment_vitals" />

    <fragment
        android:id="@+id/navigation_mood_sleep"
        android:name="com.matrusneh.app.ui.mood.MoodSleepFragment"
        android:label="Mood &amp; Sleep"
        tools:layout="@layout/fragment_mood_sleep" />

    <fragment
        android:id="@+id/navigation_ai_tip"
        android:name="com.matrusneh.app.ui.tip.AIHealthTipFragment"
        android:label="AI Health Guide"
