<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="More Options"
        android:textSize="20sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuVitals"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="@string/vitals_tracker"
        app:icon="@drawable/ic_nav_vitals" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuMood"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="@string/mood_sleep"
        app:icon="@drawable/ic_nav_mood" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuAiTip"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="@string/ai_health_guide"
        app:icon="@android:drawable/ic_menu_info_details" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuExport"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="@string/export_health_card"
        app:icon="@android:drawable/ic_menu_save" />

</LinearLayout>
