<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MatruSneh" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="colorError">@color/colorDanger</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>

        <!-- Splash Screen attributes for Android 12+ -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/colorPrimary</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_splash_lotus</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.MatruSneh.HeadlineLarge</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.MatruSneh.BodyLarge</item>
    </style>

    <style name="TextAppearance.MatruSneh.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item> <!-- Fallback for Hind -->
    </style>

    <style name="TextAppearance.MatruSneh.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item> <!-- Fallback for Hind -->
    </style>

    <style name="ShapeAppearance.MatruSneh.BottomNav" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
